OPENAI_API_KEY=your_open_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# If your Pinecone index dimension is 512, set:
# OPENAI_EMBEDDING_DIMENSIONS=512

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=rag-demo
# Optional: set this to avoid a control-plane lookup for the index host.
# PINECONE_INDEX_HOST=your-index-host.pinecone.io
# Optional namespace (leave empty for default).
PINECONE_NAMESPACE=faq
# Only used for legacy pinecone init (if needed).
PINECONE_ENVIRONMENT=us-east-1-aws
OPENAI_EMBEDDING_DIMENSIONS=512
# RAG_BACKEND=pinecone (default if PINECONE_API_KEY is set) or bm25
# RAG_TOP_K=3
# RAG_MIN_SCORE=0.25
